# ============================================================
# TripSync — 環境變數設定
# 使用方式：複製此檔案為 .env.local，再填入各項 key
#   cp .env.example .env.local
# ============================================================


# ────────────────────────────────────────────────────────────
# App 基本設定
# ────────────────────────────────────────────────────────────

# 部署後的正式網址（Vercel 會自動提供 VERCEL_URL，但建議明確設定）
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ────────────────────────────────────────────────────────────
# Supabase（接正式後端時填入）
# 取得位置：Supabase Dashboard → Project Settings → API
# ────────────────────────────────────────────────────────────

# 你的 Supabase 專案 URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# 公開 anon key（可放前端，受 RLS 保護）
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role key（僅限後端 / API Routes 使用，絕對不能給前端）
# 取得位置：Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWT Secret（驗證 token 用，若只用 Supabase Auth 內建功能可跳過）
# 取得位置：Supabase Dashboard → Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret-here


# ────────────────────────────────────────────────────────────
# Supabase Storage（封面圖片上傳）
# Bucket 名稱在 migration 004 中已建立為 "trip-images"
# ────────────────────────────────────────────────────────────

NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=trip-images

# DB Schema（固定為 tripsync，與其他專案共用 DB 時隔離用）
# Supabase Dashboard → Settings → API → Extra Schema → 填入此值
NEXT_PUBLIC_SUPABASE_SCHEMA=tripsync


# ────────────────────────────────────────────────────────────
# 本機 SQLite（目前使用中，接 Supabase 後可移除）
# 預設路徑 .data/tripsync.sqlite，不填也能正常運作
# ────────────────────────────────────────────────────────────

# DATABASE_PATH=.data/tripsync.sqlite


# ────────────────────────────────────────────────────────────
# Admin 帳號（對應 migration 003 的 trigger 設定）
# 填入你要設為 admin 的 Email，需與 Supabase Auth 中的帳號一致
# ────────────────────────────────────────────────────────────

ADMIN_EMAIL=your-admin-email@example.com


# ────────────────────────────────────────────────────────────
# Vercel 部署（通常由 Vercel 自動注入，不需手動填）
# ────────────────────────────────────────────────────────────

# VERCEL_URL 由 Vercel 自動設定，不要手動加
# 若需要在 server side 拿到完整 URL，加上這行：
# NEXT_PUBLIC_VERCEL_URL=${VERCEL_URL}
